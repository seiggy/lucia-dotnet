    <packageTypes>
      <packageType name="DotnetTool" />
    </packageTypes>
    <repository type="git" url="https://github.com/Aaronontheweb/dotnet-slopwatch" commit="8261a7d24bf91d95fb32bb844ff94409f9f0210c" />
  </metadata>
</package>