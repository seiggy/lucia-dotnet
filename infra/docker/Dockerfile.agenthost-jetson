# Lucia AgentHost - Jetson Nano ARM64 Docker Build (No Speech Pipeline)
# Purpose: Optimized image for Jetson Nano (ARM64/aarch64) without voice pipeline
#
# Target Platform: ARM64 (aarch64)
# Base Image: mcr.microsoft.com/dotnet/aspnet:10.0-noble-arm64v8 (minimal, ARM64-optimized)
# 
# Features:
#   - No speech pipeline (EXCLUDE_SPEECH=true during build)
#   - No Wyoming voice models
#   - No ONNX Runtime GPU libraries
#   - Minimal base image for resource-constrained Jetson Nano (4GB RAM)
#   - Non-root user, health checks, security hardening
#
# Build args:
#   BUILD_CONFIGURATION - Debug or Release (default: Release)
#   BUILD_TARGET_FRAMEWORK - Target framework version (default: net10.0)
#
# Usage:
#   docker build -f infra/docker/Dockerfile.agenthost-jetson -t lucia:jetson .
#   docker run -p 7233:8080 lucia:jetson

# ============================================================================
# Stage 0b: Node.js Build Stage (React SPA Dashboard)
# ============================================================================
FROM node:22-alpine@sha256:968df39aedcea65eeb078fb336ed7191baf48f972b4479711397108be0966920 AS node-build

WORKDIR /app

# Copy package files first for dependency caching
COPY lucia-dashboard/package*.json ./

# Install dependencies (clean install for reproducible builds)
RUN npm ci

# Copy the rest of the dashboard source and build
COPY lucia-dashboard/ ./
RUN npm run build

# ============================================================================
# Stage 1: Base Runtime Image (Minimal ARM64)
# ============================================================================
FROM mcr.microsoft.com/dotnet/aspnet:10.0-noble-arm64v8@sha256:0a961de5dbc02a50d4362ca2ae4e09b2c3426c1b51a6c00d336a0849643d8757 AS base

# Set working directory
WORKDIR /app

# Create non-root user for security
# UID 1100 for non-privileged access
RUN useradd -m -u 1100 appuser

# Create plugin directory with appuser ownership
# (no model directories needed — no speech pipeline on Jetson)
RUN mkdir -p /app/plugins \
    && chown -R appuser:appuser /app/plugins \
    && chmod 775 /app/plugins

# Expose ports for ASP.NET Core
# 8080: HTTP (user-facing)
# 8081: HTTPS (user-facing, with certificate)
EXPOSE 8080 8081

# ============================================================================
# Stage 2: Build Stage
# ============================================================================
FROM mcr.microsoft.com/dotnet/sdk:10.0-noble-arm64v8@sha256:a3c9e022cfe0fa95d9a19ac4a136c88c34f9d04b5029c8aedfb2098979067fcf AS build

# Set build configuration (can be overridden via --build-arg)
ARG BUILD_CONFIGURATION=Release
ARG BUILD_TARGET_FRAMEWORK=net10.0

# Set working directory
WORKDIR /src

# Copy MSBuild infrastructure files required before restore
COPY ["Directory.Build.props", "."]
COPY ["Directory.Packages.props", "."]

# Copy project files (maintaining directory structure)
COPY ["lucia.AgentHost/lucia.AgentHost.csproj", "lucia.AgentHost/"]
COPY ["lucia.Agents/lucia.Agents.csproj", "lucia.Agents/"]
COPY ["lucia.HomeAssistant/lucia.HomeAssistant.csproj", "lucia.HomeAssistant/"]
COPY ["lucia.MusicAgent/lucia.MusicAgent.csproj", "lucia.MusicAgent/"]
COPY ["lucia.ServiceDefaults/lucia.ServiceDefaults.csproj", "lucia.ServiceDefaults/"]
COPY ["lucia.TimerAgent/lucia.TimerAgent.csproj", "lucia.TimerAgent/"]
COPY ["lucia.Wyoming/lucia.Wyoming.csproj", "lucia.Wyoming/"]
COPY ["lucia.Data/lucia.Data.csproj", "lucia.Data/"]

# Restore dependencies for ARM64 architecture
# EXCLUDE_SPEECH=true to skip speech-related dependencies (ONNX Runtime, etc.)
RUN dotnet restore "./lucia.AgentHost/lucia.AgentHost.csproj" \
      --runtime linux-arm64 \
      /p:PublishReadyToRun=true \
      /p:CopilotSkipCliDownload=true \
      /p:ExcludeSpeech=true

# Copy entire source tree
COPY . .

# Remove global.json — the SDK image determines the version in containers
RUN rm -f global.json

# Build the application with ExcludeSpeech flag
WORKDIR "/src"

RUN dotnet build "./lucia.AgentHost/lucia.AgentHost.csproj" \
    -c $BUILD_CONFIGURATION \
    -o /app/build \
    --runtime linux-arm64 \
    --framework $BUILD_TARGET_FRAMEWORK \
    --no-restore \
    /p:CopilotSkipCliDownload=true \
    /p:ExcludeSpeech=true

# ============================================================================
# Stage 3: Publish Stage
# ============================================================================
FROM build AS publish

# Build configuration (matches build stage)
ARG BUILD_CONFIGURATION=Release
ARG BUILD_TARGET_FRAMEWORK=net10.0

# Publish to /app/publish directory for ARM64 without speech support
RUN dotnet publish "./lucia.AgentHost/lucia.AgentHost.csproj" \
    -c $BUILD_CONFIGURATION \
    -o /app/publish \
    --no-restore \
    --framework $BUILD_TARGET_FRAMEWORK \
    --runtime linux-arm64 \
    /p:UseAppHost=false \
    /p:PublishTrimmed=false \
    /p:PublishReadyToRun=true \
    /p:CopilotSkipCliDownload=true \
    /p:ExcludeSpeech=true

# ============================================================================
# Stage 4: Final Production Image (Minimal for Jetson Nano)
# ============================================================================
FROM base AS final

# Set metadata labels
LABEL maintainer="Lucia Project"
LABEL description="Lucia Agent Host - ARM64 Jetson Nano (without speech pipeline)"
LABEL version="1.0.0"
LABEL platform="linux/arm64"

# Set environment variables for .NET runtime
ENV DOTNET_SYSTEM_GLOBALIZATION_INVARIANT=false \
    DOTNET_RUNNING_IN_CONTAINER=true \
    ASPNETCORE_URLS=http://+:8080;https://+:8081 \
    COMPlus_EnableDiagnostics=0

# Copy published application from publish stage
COPY --from=publish --chown=appuser:appuser /app/publish .

# Copy built SPA dashboard into wwwroot for static file serving
COPY --from=node-build --chown=appuser:appuser /app/dist ./wwwroot/

# Copy official plugins (MetaMCP, SearXNG) so env-based tools are registered at startup
COPY --from=build --chown=appuser:appuser /src/plugins ./plugins

# PluginDirectory default is {AppContext.BaseDirectory}/plugins = /app/plugins
ENV PluginDirectory=/app/plugins

# Volume declarations for persistent storage
# /app/plugins: Plugin directory (future-proofing for runtime plugin management)
VOLUME ["/app/plugins"]

# Switch to non-root user for runtime security
USER appuser

# Health check for container orchestration
# Tests HTTP endpoint to verify service is responding
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8080/health || exit 1

# Application entry point
# Runs the .NET application
ENTRYPOINT ["dotnet", "lucia.AgentHost.dll"]

# Build examples:
#
#   # Standard ARM64 build for Jetson Nano (no speech pipeline)
#   docker build -f infra/docker/Dockerfile.agenthost-jetson -t lucia:jetson .
#
#   # Debug build for troubleshooting
#   docker build --build-arg BUILD_CONFIGURATION=Debug -f infra/docker/Dockerfile.agenthost-jetson -t lucia:jetson-debug .
#
#   # On non-ARM64 host, use buildx for cross-compilation
#   docker buildx build -f infra/docker/Dockerfile.agenthost-jetson --platform linux/arm64 -t lucia:jetson .
