{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning",
      "MongoDb": "Warning"
    }
  },
  "HomeAssistant": {
    "BaseUrl": "http://homeassistant.local:8123",
    "AccessToken": "", // you have to create a Long-Lived Access Token in your Home Assistant user profile
    "TimeoutSeconds": 60,
    "ValidateSSL":  false
  },
  "Wyoming": {
    "Port": 10400,
    "Host": "0.0.0.0",
    "MaxWakeWordStreams": 30,
    "MaxConcurrentSttSessions": 4,
    "MaxConcurrentTtsSyntheses": 2,
    "ServiceName": "lucia-wyoming",
    "Models": {
      "Stt": {
        "ModelPath": "",
        "NumThreads": 4,
        "SampleRate": 16000,
        "ActiveModel": "sherpa-onnx-streaming-zipformer-en-2023-06-26",
        "ModelBasePath": "./models/stt",
        "AllowCustomModels": true,
        "AutoDownloadDefault": true
      },
      "Vad": {
        "ModelPath": "",
        "Threshold": 0.5,
        "MinSpeechDuration": 0.25,
        "MinSilenceDuration": 0.5,
        "SampleRate": 16000
      },
      "WakeWord": {
        "ModelPath": "",
        "DefaultKeywords": [ "hey lucia" ],
        "KeywordsFile": "",
        "Sensitivity": 0.5,
        "MaxConcurrentKeywords": 10,
        "AllowCustomWakeWords": true
      }
    }
  },
  "AllowedHosts": "*",
  "RouterExecutor": {
    "ConfidenceThreshold": 0.7,
    "MaxAttempts": 2,
    "Temperature": 1.0,
    "MaxOutputTokens": 512,
    "IncludeAgentCapabilities": true,
    "IncludeSkillExamples": false
  },
  "AgentInvoker": {
    "Timeout": "00:00:30"
  },
  "ResultAggregator": {
    "DefaultFallbackMessage": "I encountered an issue processing your request. Please try again.",
    "EnableNaturalLanguageJoining": true
  },
  "SessionCache": {
    "SessionCacheLengthMinutes": 5,
    "MaxHistoryItems": 20
  },
  "Redis": {
    "TaskTtlHours": 24,
    "PromptCacheTtlHours": 48,
    "ConnectRetryCount": 3,
    "ConnectTimeout": 5000
  },
  "ConnectionStrings": {
    "ollama-phi3-mini": "Endpoint=http://localhost:11434;Model=phi3:mini;Provider=ollama",
    "ollama-llama3-2-3b": "Endpoint=http://localhost:11434;Model=llama3.2:3b;Provider=ollama",
    "redis": "localhost:6379"
  },
  "Agents": [
    {
      "AgentName": "light-agent",
      "AgentType": "lucia.Agents.Agents.LightAgent",
      "AgentSkills": [ "lucia.Agents.Skills.LightControlSkill" ],
      "ModelConnectionName": null
    },
    {
      "AgentName": "general-assistant",
      "AgentType": "lucia.Agents.Agents.GeneralAgent",
      "AgentSkills": [],
      "ModelConnectionName": null
    },
    {
      "AgentName": "router",
      "AgentType": "lucia.Agents.Orchestration.LuciaOrchestrator",
      "AgentSkills": [],
      "ModelConnectionName": null
    }
  ],
  "TraceCapture": {
    "Enabled": true,
    "RetentionDays": 30,
    "RedactionPatterns": [
      "(?i)(api[_-]?key|token|secret|password|bearer)\\s*[:=]\\s*\\S+",
      "eyJ[A-Za-z0-9_-]+\\.eyJ[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+"
    ],
    "DatabaseName": "luciatraces",
    "TracesCollectionName": "traces",
    "ExportsCollectionName": "exports"
  },
  "MusicAssistant": {
    "IntegrationId": "" // you have to find this in the /config/.storage/core.config_entries file, then search for music_assistant, and grab the entry_id
  },
  "TimerAgent": {
  },
  "LightControlSkill": {
    "EntityDomains": ["light", "switch"],
    "HybridSimilarityThreshold": 0.55,
    "EmbeddingWeight": 0.4,
    "ScoreDropoffRatio": 0.80,
    "DisagreementPenalty": 0.4,
    "EmbeddingResolutionMargin": 0.30,
    "CacheRefreshMinutes": 30
  },
  "ClimateControlSkill": {
    "EntityDomains": ["climate"],
    "HybridSimilarityThreshold": 0.55,
    "EmbeddingWeight": 0.4,
    "ScoreDropoffRatio": 0.80,
    "DisagreementPenalty": 0.4,
    "EmbeddingResolutionMargin": 0.30,
    "CacheRefreshMinutes": 30
  },
  "FanControlSkill": {
    "EntityDomains": ["fan"],
    "HybridSimilarityThreshold": 0.55,
    "EmbeddingWeight": 0.4,
    "ScoreDropoffRatio": 0.80,
    "DisagreementPenalty": 0.4,
    "EmbeddingResolutionMargin": 0.30,
    "CacheRefreshMinutes": 5
  },
  "MusicPlaybackSkill": {
    "EntityDomains": ["media_player"],
    "HybridSimilarityThreshold": 0.55,
    "EmbeddingWeight": 0.4,
    "ScoreDropoffRatio": 0.80,
    "DisagreementPenalty": 0.4,
    "EmbeddingResolutionMargin": 0.30,
    "CacheRefreshMinutes": 30
  },
  "SceneControlSkill": {
    "EntityDomains": ["scene"],
    "HybridSimilarityThreshold": 0.55,
    "EmbeddingWeight": 0.4,
    "ScoreDropoffRatio": 0.80,
    "DisagreementPenalty": 0.4,
    "EmbeddingResolutionMargin": 0.30
  }
}
